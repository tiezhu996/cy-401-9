# Compose project name is fixed so Chinese or arbitrary parent directory names do not affect container names.
COMPOSE_PROJECT_NAME=cyfreelance

# MySQL database and credentials.
DB_NAME=freelance
DB_USER=freelance
DB_PASSWORD=freelance_pwd
DB_ROOT_PASSWORD=root_pwd

# JWT signing secret. Replace this before production deployment.
JWT_SECRET=change_me_to_a_long_random_string

# Host ports. Frontend is served by Nginx and proxies /api to backend.
FRONTEND_PORT=28030
BACKEND_PORT=29068
DB_PORT=38101

# Keep true for the demo MVP; use migrations and set false in production.
TYPEORM_SYNC=true
